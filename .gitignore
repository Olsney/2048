# This .gitignore file should be placed at the root of your Unity project directory
#
# Get latest from https://github.com/github/gitignore/blob/main/Unity.gitignore
#
/src/2048/.utmp/
/src/2048/[Ll]ibrary/
/src/2048/[Tt]emp/
/src/2048/[Oo]bj/
/src/2048/[Bb]uild/
/src/2048/[Bb]uilds/
/src/2048/[Ll]ogs/
/src/2048/[Uu]ser[Ss]ettings/
/src/2048/*.log

# MemoryCaptures can get excessive in size.
# They also could contain extremely sensitive data
/src/2048/[Mm]emoryCaptures/

# Recordings can get excessive in size
/src/2048/[Rr]ecordings/

# Uncomment this line if you wish to ignore the asset store tools plugin
# /src/2048/[Aa]ssets/AssetStoreTools*

# Autogenerated Jetbrains Rider plugin
/src/2048/[Aa]ssets/Plugins/Editor/JetBrains*

# Visual Studio cache directory
/src/2048/.vs/

# Gradle cache directory
/src/2048/.gradle/

# Autogenerated VS/MD/Consulo solution and project files
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
/src/2048/sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.unitypackage.meta
*.app

# Crashlytics generated file
/src/2048/crashlytics-build.properties

# Packed Addressables
/src/2048/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Temporary auto-generated Android Assets
/src/2048/[Aa]ssets/[Ss]treamingAssets/aa.meta
/src/2048/[Aa]ssets/[Ss]treamingAssets/aa/*

# OS junk
**/.DS_Store
**/Thumbs.db
**/Desktop.ini

# JetBrains (Rider/IDEA) project files
/src/2048/.idea/
**/.idea/
**/.Rider/
*.sln.DotSettings.user
*.DotSettings.user

# VS Code
**/.vscode/

# Rider/VS additional caches
**/.fleet/
**/.cache/